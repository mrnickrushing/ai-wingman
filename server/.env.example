DATABASE_URL=postgresql://user:password@localhost:5432/ai_wingman
# Set for public TLS connections that use a private CA. Keep certificate
# verification enabled; private Railway networking can use PGSSLMODE=disable.
PGSSLMODE=disable
PGSSLROOTCERT=
JWT_SECRET=replace_with_at_least_32_random_characters

# Comma-separated public OAuth client IDs accepted in verified id_token aud claims.
GOOGLE_CLIENT_IDS=your_web_client_id.apps.googleusercontent.com,your_ios_client_id.apps.googleusercontent.com
APPLE_CLIENT_IDS=com.rushingtechnologies.aiwingman

# Secret server key from RevenueCat. Never expose this through EXPO_PUBLIC_*.
REVENUECAT_SECRET_API_KEY=your_revenuecat_secret_api_key
REVENUECAT_ENTITLEMENT_ID=pro
# Configure either (preferably both) on the RevenueCat webhook integration.
REVENUECAT_WEBHOOK_AUTH=Bearer replace_with_a_random_authorization_value
REVENUECAT_WEBHOOK_SIGNING_SECRET=replace_with_revenuecat_webhook_signing_secret

# Required, positive fair-use allowance enforced from server-observed WS time.
MONTHLY_MINUTES_CAP=300
# Comma-separated web origins. Native mobile clients do not send Origin.
CORS_ORIGINS=https://your-web-app.example.com
ADMIN_API_KEY=replace_with_a_random_admin_key

DEEPGRAM_API_KEY=your_deepgram_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
BRAINTRUST_API_KEY=
PORT=3001
