# WebSocket server URL — replace with your Railway URL after deployment
EXPO_PUBLIC_SERVER_URL=wss://wingman-server-production-5146.up.railway.app/ws

# Expo project ID for OTA updates (expo-updates).
# Set this in the EAS build environment (see eas.json). When empty, OTA updates
# are disabled and the app still launches normally.
EAS_PROJECT_ID=

# Google OAuth client IDs for Expo AuthSession
# Web client ID is required. iOS/Android client IDs improve native sign-in flows
# when you have separate iOS/Android OAuth clients configured in Google Cloud Console.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=3252464813-etbtbe2sgeveqkg7c7j72b3071n8d1cq.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=
