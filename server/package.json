{
  "name": "ai-wingman-server",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx --import braintrust/hook.mjs src/index.ts",
    "build": "tsc",
    "migrate": "tsx src/db/migrate-cli.ts",
