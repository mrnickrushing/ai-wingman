    "bcryptjs": "^3.0.3",
    "braintrust": "^3.20.0",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "google-auth-library": "^10.9.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.22.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.11.6",
    "@types/ws": "^8.5.13",
    "eslint": "^9.39.5",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "8.55.0"
  }
