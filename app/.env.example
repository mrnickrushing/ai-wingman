# WebSocket server URL — replace with your Railway URL after deployment
EXPO_PUBLIC_SERVER_URL=wss://wingman-server-production-5146.up.railway.app/ws

# Expo project ID for OTA updates (expo-updates).
# Set this in the EAS build environment (see eas.json). When empty, OTA updates
# are disabled and the app still launches normally.
EAS_PROJECT_ID=

# Google OAuth client IDs for Expo AuthSession
# Web client ID is required. iOS/Android client IDs improve native sign-in flows
# when you have separate iOS/Android OAuth clients configured in Google Cloud Console.
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=3252464813-d766karmag0gu0ul1tan5125a82nnjar.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=3252464813-f3ki3imith7n3aomtnvknlismga84ba0.apps.googleusercontent.com
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_EXPO_CLIENT_ID=

# RevenueCat (react-native-purchases) API keys. Without a platform key set,
# the app shows a disabled-purchases state on that platform instead of
# crashing. See eas.json / codemagic.yaml for the values used in CI builds.
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
EXPO_PUBLIC_REVENUECAT_ENTITLEMENT_ID=pro
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_PACKAGE_ID=\$rc_monthly
