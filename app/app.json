{
  "expo": {
    "name": "AI Wingman",
    "slug": "ai-wingman",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.rushingtechnologies.aiwingman",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "AI Wingman uses the microphone during sessions you start to transmit and transcribe conversation audio for real-time coaching.",
        "NSBluetoothAlwaysUsageDescription": "AI Wingman uses Bluetooth to whisper coaching through your AirPods.",
        "NSFaceIDUsageDescription": "AI Wingman uses Face ID to protect your account.",
        "UIBackgroundModes": [
          "audio"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.rushingtechnologies.aiwingman",
      "permissions": [
        "RECORD_AUDIO",
        "BLUETOOTH",
        "BLUETOOTH_CONNECT"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "aiwingman"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "plugins": [
      [
        "expo-audio",
        {
          "microphonePermission": "AI Wingman uses the microphone during sessions you start to transmit and transcribe conversation audio for real-time coaching.",
          "enableBackgroundRecording": true,
          "enableBackgroundPlayback": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "resizeMode": "contain",
          "backgroundColor": "#0A0A14"
        }
      ],
      "expo-secure-store",
      "expo-apple-authentication",
      "expo-web-browser",
      "expo-sharing",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#6366f1",
          "sounds": []
        }
      ]
    ],
    "scheme": "aiwingman",
    "extra": {
      "serverUrl": "wss://wingman-server-production-5146.up.railway.app/ws"
    }
  }
}
